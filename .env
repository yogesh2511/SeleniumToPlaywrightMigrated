# Base URL for the UI application under test
BASE_URL=https://www.labcorp.com

# API base URL
API_BASE_URL=https://echo.free.beeceptor.com

# Browser: chromium | firefox | webkit
BROWSER=chromium

# Run tests in headless mode: true | false
HEADLESS=false

# Default timeout in milliseconds
DEFAULT_TIMEOUT=30000

# Disable browser notifications
DISABLE_NOTIFICATIONS=true

# Debug mode (verbose request/response logging for API)
DEBUG=false
